#!/bin/bash
#
# cc99 - ClaudeC99 compiler frontend
#
# Compiles one or more C source files to an executable (or intermediate
# form) using ccompiler, nasm, and gcc.
#
# Usage:
#   cc99 [options] file.c [file2.c ...]
#
# Options:
#   --version        Print compiler version and exit
#   -o <file>        Output file name (default: a.out)
#   -c               Compile and assemble only; produce .o files, no link
#   -S               Compile only; produce .asm files, no assemble or link
#   --print-ast      Print AST to stdout and exit (no output file)
#   --print-tokens   Print token stream to stdout and exit (no output file)
#   -D NAME[=VAL]    Define a preprocessor macro
#   -I <dir>         Add directory to include search path
#   -I<dir>          (same, one-argument form)
#   --sysroot=<dir>  Set virtual filesystem root for absolute -I paths
#   -Werror          Treat warnings as errors
#   --max-errors=N   Stop after N errors (0 = unlimited)
#   -l <lib>         Link with library (passed to gcc)
#   -l<lib>          (same, one-argument form)
#   -L <dir>         Add library search path (passed to gcc)
#   -L<dir>          (same, one-argument form)

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
COMPILER="$SCRIPT_DIR/ccompiler"
# Stub system headers (stdio.h, stddef.h, etc.) — appended after user -I flags
# so user-supplied paths take precedence, matching the test harness convention.
DEFAULT_IFLAGS=("-I$PROJECT_DIR/test/include")

# System include paths used by --sysinclude (Linux x86_64 only)
SYSINCLUDE_IFLAGS=(
    "-I/usr/lib/gcc/x86_64-linux-gnu/13/include"
    "-I/usr/local/include"
    "-I/usr/include/x86_64-linux-gnu"
    "-I/usr/include"
)

usage() {
    cat >&2 <<'EOF'
Usage: cc99 [options] file.c [file2.c ...]

Options:
  --version        Print compiler version and exit
  -o <file>        Output file name (default: a.out)
  -c               Compile and assemble only; produce .o files
  -S               Compile only; produce .asm files
  --print-ast      Print AST to stdout and exit (no output file)
  --print-tokens   Print token stream to stdout and exit (no output file)
  -D NAME[=VAL]    Define a preprocessor macro
  -I <dir>         Add directory to include search path
  --sysroot=<dir>  Set virtual filesystem root for absolute -I paths
  --sysinclude     Use system include paths instead of test/include stubs
                   (Linux x86_64 only)
  -O0              Disable optimization (default)
  -O1              Enable AST-level optimization
  -g               Emit DWARF debug information
  -Werror          Treat warnings as errors
  --max-errors=N   Stop after N errors (0 = unlimited)
  -l <lib>         Link with library
  -L <dir>         Add library search path
EOF
}

if [[ $# -eq 0 ]]; then
    usage
    exit 1
fi

if [[ ! -x "$COMPILER" ]]; then
    echo "cc99: compiler not found at $COMPILER" >&2
    echo "cc99: copy build/ccompiler to $(dirname "$0")/" >&2
    exit 1
fi

# ── argument parsing ──────────────────────────────────────────────────────────

output="a.out"
mode="link"           # link | compile-only | asm-only | print
compiler_flags=()
link_flags=()
input_files=()
use_sysinclude=0

while [[ $# -gt 0 ]]; do
    case "$1" in
        --version)
            exec "$COMPILER" --version ;;
        -o)
            [[ $# -lt 2 ]] && { echo "cc99: -o requires an argument" >&2; exit 1; }
            output="$2"; shift 2 ;;
        -o*)
            output="${1#-o}"; shift ;;
        -c)
            mode="compile-only"; shift ;;
        -S)
            mode="asm-only"; shift ;;
        --print-ast|--print-tokens)
            mode="print"; compiler_flags+=("$1"); shift ;;
        -Werror)
            compiler_flags+=("$1"); shift ;;
        -O0|-O1|-g)
            compiler_flags+=("$1"); shift ;;
        --max-errors=*)
            compiler_flags+=("$1"); shift ;;
        -D*)
            compiler_flags+=("$1"); shift ;;
        -I)
            [[ $# -lt 2 ]] && { echo "cc99: -I requires an argument" >&2; exit 1; }
            # Resolve relative path so it stays valid when compiler runs from tmpdir
            dir="$2"
            [[ "$dir" != /* ]] && dir="$(pwd)/$dir"
            compiler_flags+=("-I$dir"); shift 2 ;;
        -I*)
            dir="${1#-I}"
            [[ "$dir" != /* ]] && dir="$(pwd)/$dir"
            compiler_flags+=("-I$dir"); shift ;;
        --sysroot=*)
            compiler_flags+=("$1"); shift ;;
        --sysinclude)
            if [[ "$(uname -s)" != "Linux" || "$(uname -m)" != "x86_64" ]]; then
                echo "cc99: --sysinclude is only supported on Linux x86_64" >&2
                exit 1
            fi
            use_sysinclude=1; shift ;;
        -l)
            [[ $# -lt 2 ]] && { echo "cc99: -l requires an argument" >&2; exit 1; }
            link_flags+=("-l$2"); shift 2 ;;
        -l*)
            link_flags+=("$1"); shift ;;
        -L)
            [[ $# -lt 2 ]] && { echo "cc99: -L requires an argument" >&2; exit 1; }
            link_flags+=("-L$2"); shift 2 ;;
        -L*)
            link_flags+=("$1"); shift ;;
        --)
            shift; input_files+=("$@"); break ;;
        -*)
            echo "cc99: unrecognized option: $1" >&2; exit 1 ;;
        *.c)
            input_files+=("$1"); shift ;;
        *)
            echo "cc99: unrecognized input: $1" >&2; exit 1 ;;
    esac
done

if [[ ${#input_files[@]} -eq 0 ]]; then
    echo "cc99: no input files" >&2
    exit 1
fi

# -o with multiple files in -c / -S mode is not meaningful
if [[ ${#input_files[@]} -gt 1 && "$mode" != "link" && "$output" != "a.out" ]]; then
    echo "cc99: warning: -o ignored with multiple input files in -c/-S mode" >&2
    output="a.out"
fi

# ── debug flag detection ──────────────────────────────────────────────────────
emit_debug=0
for cflag in "${compiler_flags[@]}"; do
    if [[ "$cflag" == "-g" ]]; then emit_debug=1; break; fi
done

# ── compilation loop ──────────────────────────────────────────────────────────

tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT

obj_files=()

for src in "${input_files[@]}"; do
    abs_src="$(realpath "$src" 2>/dev/null)"
    if [[ -z "$abs_src" || ! -f "$abs_src" ]]; then
        echo "cc99: $src: no such file" >&2
        exit 1
    fi

    base="$(basename "$src" .c)"
    asm_out="$tmpdir/${base}.asm"
    obj_out="$tmpdir/${base}.o"

    # ── compile: .c → .asm ───────────────────────────────────────────────────
    # Run compiler from tmpdir so the .asm output lands there
    if [[ "$use_sysinclude" -eq 1 ]]; then
        active_iflags=("${SYSINCLUDE_IFLAGS[@]}")
    else
        active_iflags=("${DEFAULT_IFLAGS[@]}")
    fi
    if ! (cd "$tmpdir" && "$COMPILER" "${compiler_flags[@]}" "${active_iflags[@]}" "$abs_src"); then
        exit 1
    fi

    if [[ "$mode" == "print" ]]; then
        continue
    fi

    if [[ "$mode" == "asm-only" ]]; then
        dest="${base}.asm"
        [[ ${#input_files[@]} -eq 1 && "$output" != "a.out" ]] && dest="$output"
        cp "$asm_out" "$dest"
        continue
    fi

    # ── assemble: .asm → .o ──────────────────────────────────────────────────
    nasm_debug_flags=()
    [[ "$emit_debug" -eq 1 ]] && nasm_debug_flags=(-g -F dwarf)
    if ! nasm -f elf64 "${nasm_debug_flags[@]}" "$asm_out" -o "$obj_out"; then
        echo "cc99: assembly failed for $src" >&2
        exit 1
    fi

    if [[ "$mode" == "compile-only" ]]; then
        dest="${base}.o"
        [[ ${#input_files[@]} -eq 1 && "$output" != "a.out" ]] && dest="$output"
        cp "$obj_out" "$dest"
        continue
    fi

    obj_files+=("$obj_out")
done

# ── link ──────────────────────────────────────────────────────────────────────
if [[ "$mode" == "link" ]]; then
    if ! gcc -no-pie "${obj_files[@]}" "${link_flags[@]}" -o "$output"; then
        echo "cc99: link failed" >&2
        exit 1
    fi
fi

section .text
global main
main:
    push rbp
    mov rbp, rsp
    sub rsp, 16
    mov [rbp - 8], rbx
    lea rax, [rel Lstr0]
    mov [rbp - 16], rax
    mov eax, 0
    mov rbx, [rbp - 8]
    mov rsp, rbp
    pop rbp
    ret
section .rodata
Lstr0:
    db 104, 105, 0

section .note.GNU-stack noalloc noexec nowrite progbits

section .text
global main
main:
    push rbp
    mov rbp, rsp
    sub rsp, 32
    mov [rbp - 8], rbx
    mov byte [rbp - 11], 104
    mov byte [rbp - 10], 105
    mov byte [rbp - 9], 0
    mov eax, 0
    mov rbx, [rbp - 8]
    mov rsp, rbp
    pop rbp
    ret

section .note.GNU-stack noalloc noexec nowrite progbits

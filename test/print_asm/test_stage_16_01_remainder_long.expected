section .text
global main
main:
    push rbp
    mov rbp, rsp
    sub rsp, 16
    mov rax, 20
    mov [rbp - 8], rax
    mov rax, 6
    mov [rbp - 16], rax
    mov rax, [rbp - 8]
    push rax
    mov rax, [rbp - 16]
    pop rcx
    xchg rax, rcx
    cqo
    idiv rcx
    mov rax, rdx
    mov rsp, rbp
    pop rbp
    ret

section .bss
global g
g: resd 1
global c
c: resb 1
global s
s: resw 1
global l
l: resq 1
global p
p: resq 1
global arr
arr: resb 40
section .text
global main
main:
    push rbp
    mov rbp, rsp
    mov eax, 1
    mov [rel g], eax
    mov eax, [rel g]
    mov rsp, rbp
    pop rbp
    ret

section .note.GNU-stack noalloc noexec nowrite progbits

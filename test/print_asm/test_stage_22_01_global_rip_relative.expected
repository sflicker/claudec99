section .bss
global g
g: resd 1
section .text
global main
main:
    push rbp
    mov rbp, rsp
    sub rsp, 16
    mov [rbp - 8], rbx
    mov eax, 42
    mov [rel g], eax
    mov eax, [rel g]
    mov rbx, [rbp - 8]
    mov rsp, rbp
    pop rbp
    ret

section .note.GNU-stack noalloc noexec nowrite progbits
